# Copy this file to .env.development for local dev and set your API origin
# Vite will read VITE_* variables at build-time

# Backend origin (protocol+host+port). Do NOT include a path like /api here.
# Example for local dev backend running on port 5000:
VITE_API_URL=http://localhost:5000

# Optional: if you need to change the API prefix (defaults to /api)
# VITE_API_PREFIX=/api

# Stripe Publishable Key (required for payment processing)
# Get yours at https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# --- SEO ---
# Public canonical origin where the SPA is served (NO trailing slash).
# Used to build canonical URLs, Open Graph URLs, sitemap entries, etc.
# IMPORTANT: this value MUST match the domain where users actually open the site.
# Current staging/production-pre-domain value:
VITE_SITE_URL=https://novofixfrontenddev.vercel.app
# When the definitive domain is live, change to:
# VITE_SITE_URL=https://novofix.com
# Display name used in <title>, og:site_name, JSON-LD Organization, etc.
VITE_SITE_NAME=NovoFix
# Optional Twitter/X handle (with @). Leave empty if not applicable.
VITE_TWITTER_HANDLE=

# --- SEO · Geo (Phase 8: keyword targeting + local SEO Miami/FL) ---
# Used by buildLocalBusinessSchema() and <meta name="geo.*"> tags.
VITE_SITE_CITY=Miami
VITE_SITE_REGION=FL
VITE_SITE_COUNTRY=US
# Human-readable region label used in copy/JSON-LD (optional).
VITE_SITE_REGION_LABEL=Florida
# Comma-separated list of areas served (used for areaServed in LocalBusiness).
VITE_SITE_AREAS=Miami-Dade County,Broward County,Palm Beach County
# Optional contact info surfaced in LocalBusiness JSON-LD (helps mobile SERP "Call" button).
# VITE_SITE_PHONE=+1-305-000-0000
# VITE_SITE_EMAIL=contacto@novofix.com